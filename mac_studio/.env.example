# =============================================
# WhisperX Mac Studio – Environment Variables
# =============================================
# Kopiere diese Datei nach .env und passe die Werte an:
#   cp .env.example .env

# --- Authentifizierung ---
WHISPER_AUTH_USERNAME=admin
WHISPER_AUTH_PASSWORD=password123

# --- Worker Pool ---
# Anzahl paralleler WhisperX-Instanzen
# Jede Instanz benötigt ~6 GB (large-v3 + Alignment)
#
# Empfohlene Werte:
#   M3 Ultra 256GB / 60C GPU → 6-8  Worker
#   M3 Ultra 512GB / 60C GPU → 8-15 Worker
#   M3 Ultra 512GB / 80C GPU → 12-20 Worker (mehr GPU-Cores = mehr Parallelität)
#
# Faustregel: (Verfügbarer RAM - LLM - 20GB System) / 6 GB = max Worker
# Bei 512GB + Q4 LLM (16GB): (512 - 16 - 20) / 6 ≈ 79 theoretisch,
# aber GPU-Cores limitieren auf ~20 sinnvolle Worker bei 80C
WHISPERX_POOL_SIZE=6

# --- Ollama LLM (Nachkontrolle) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral-small
LLM_TIMEOUT=120

# --- Alternative: OpenAI-kompatible API ---
# (Leer lassen wenn Ollama genutzt wird)
LLM_OPENAI_BASE_URL=
LLM_OPENAI_API_KEY=not-needed
LLM_OPENAI_MODEL=mistral-small

# --- MPS Tuning ---
# Anteil des Unified Memory den MPS nutzen darf (0.0-1.0)
# 0.7 = 70% von 256GB ≈ 179 GB für ML-Modelle
PYTORCH_MPS_HIGH_WATERMARK_RATIO=0.7
# Erlaubt CPU-Fallback für nicht-MPS-unterstützte Operationen
PYTORCH_ENABLE_MPS_FALLBACK=1
